generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- ユーザー ---
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  displayName String?  @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  supabaseId  String   @unique @map("supabase_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  trips      Trip[]
  tripShares TripShare[]

  @@map("users")
}

// --- 旅行プラン ---
model Trip {
  id            String     @id @default(cuid())
  userId        String     @map("user_id")
  title         String
  destination   String
  startDate     DateTime   @map("start_date") @db.Date
  endDate       DateTime   @map("end_date") @db.Date
  totalBudget   Int        @map("total_budget")
  currency      String     @default("JPY")
  travelStyle   String?    @map("travel_style")
  coverImageUrl String?    @map("cover_image_url")
  status        TripStatus @default(DRAFT)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tripDays         TripDay[]
  budgetCategories BudgetCategory[]
  tripShares       TripShare[]

  @@index([userId])
  @@map("trips")
}

enum TripStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  COMPLETED
}

// --- 旅行日 ---
model TripDay {
  id        String   @id @default(cuid())
  tripId    String   @map("trip_id")
  dayNumber Int      @map("day_number")
  date      DateTime @db.Date
  memo      String?

  trip           Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  itineraryItems ItineraryItem[]

  @@unique([tripId, dayNumber])
  @@index([tripId])
  @@map("trip_days")
}

// --- 旅程アイテム ---
model ItineraryItem {
  id            String   @id @default(cuid())
  tripDayId     String   @map("trip_day_id")
  orderIndex    Int      @map("order_index")
  type          ItemType
  title         String
  description   String?
  startTime     String?  @map("start_time")
  endTime       String?  @map("end_time")
  latitude      Float?
  longitude     Float?
  placeId       String?  @map("place_id")
  address       String?
  estimatedCost Int?     @map("estimated_cost")
  imageUrl      String?  @map("image_url")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tripDay  TripDay   @relation(fields: [tripDayId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@index([tripDayId])
  @@map("itinerary_items")
}

enum ItemType {
  ATTRACTION
  RESTAURANT
  TRANSPORT
  ACCOMMODATION
  ACTIVITY
  OTHER
}

// --- 実績支出 ---
model Expense {
  id               String          @id @default(cuid())
  itineraryItemId  String?         @map("itinerary_item_id")
  tripId           String          @map("trip_id")
  category         ExpenseCategory
  title            String
  amount           Int
  originalAmount   Int?            @map("original_amount")
  originalCurrency String?         @map("original_currency")
  paidAt           DateTime?       @map("paid_at")
  createdAt        DateTime        @default(now()) @map("created_at")

  itineraryItem ItineraryItem? @relation(fields: [itineraryItemId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@map("expenses")
}

enum ExpenseCategory {
  TRANSPORT
  ACCOMMODATION
  FOOD
  ATTRACTION
  SHOPPING
  OTHER
}

// --- 予算カテゴリ ---
model BudgetCategory {
  id           String          @id @default(cuid())
  tripId       String          @map("trip_id")
  category     ExpenseCategory
  budgetAmount Int             @map("budget_amount")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, category])
  @@map("budget_categories")
}

// --- 旅行共有 ---
model TripShare {
  id         String     @id @default(cuid())
  tripId     String     @map("trip_id")
  userId     String?    @map("user_id")
  email      String?
  permission Permission @default(VIEW)
  shareToken String     @unique @map("share_token")
  createdAt  DateTime   @default(now()) @map("created_at")

  trip Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("trip_shares")
}

enum Permission {
  VIEW
  EDIT
}
